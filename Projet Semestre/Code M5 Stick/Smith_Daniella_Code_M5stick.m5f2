ic_on_setup\" id=\"setup_block\" deletable=\"false\" x=\"110\" y=\"230\"><mutation isBegin=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_begin\" id=\"system_m5_begin\"><next><block type=\"i2c_init\" id=\"ZoKy`QU~5rAXY;:}_ttp\"><field name=\"NAME\">0</field><field name=\"FREQ\">100000</field><value name=\"SCL\"><shadow type=\"math_number\" id=\"f0,%LzS~zrOslQ?Mfhv{\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">33</field></shadow></value><value name=\"SDA\"><shadow type=\"math_number\" id=\"~/c|Y-mzdX/|-JY=y*s^\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">32</field></shadow></value><next><block type=\"variables_set\" id=\"^UVQ)ftjd[/wzNx7=Ppc\"><field name=\"VAR\" id=\"Y4v?s=zLh5G5f:/a:lH2\">Date</field><value name=\"VALUE\"><block type=\"time_get_utc_time\" id=\"RYulRwfUY6ze*-xYl7a(\"></block></value><next><block type=\"unit_env_init\" id=\"[]ot2qKXqSshoql~IvP1\"><field name=\"NAME\">env4_0</field></block></next></block></next></block></next></block></statement></block><block type=\"variables_set\" id=\"SAMY6O#uD~YA@p:O}}}@\" disabled=\"true\" x=\"-10\" y=\"550\"><field name=\"VAR\" id=\"_Y}|K9j9OzbE%reV},8]\">Temp</field><value name=\"VALUE\"><block type=\"math_number\" id=\"IEYGO?I[1l^b!MW`(X12\" disabled=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">0</field></block></value><next><block type=\"variables_set\" id=\"J8B^K/VHKvbIk%XMm5+z\" disabled=\"true\"><field name=\"VAR\" id=\"U7KD#wS|qPgVMKy{?{|W\">Humidity</field><value name=\"VALUE\"><block type=\"math_number\" id=\"-Se}vd)cK8?PBehRoT+^\" disabled=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">0</field></block></value><next><block type=\"variables_set\" id=\"X9)%rFdHm-R7*-4$PQ?X\" disabled=\"true\"><field name=\"VAR\" id=\"5Q1{:ThLf]%jBug3}BQ(\">Pressure</field><value name=\"VALUE\"><block type=\"math_number\" id=\"pj,GIIcD$$:}IV4}F!u=\" disabled=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">0</field></block></value><next><block type=\"variables_set\" id=\"gcV/HN}Fzj,x_)Z(s{EM\" disabled=\"true\"><field name=\"VAR\" id=\"_Y}|K9j9OzbE%reV},8]\">Temp</field><value name=\"VALUE\"><block type=\"math_number\" id=\"~ti$NqxQfn5JQK`adD1{\" disabled=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">0</field></block></value></block></next></block></next></block></next></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":135,"height":240,"scale":0.67,"screenName":"","blockId":"","screenColorType":0,"rotation":3,"id":"builtin","createTime":1732263488461}],"logicWhenNum":0,"pythonCode":"import os, sys, io\nimport M5\nfrom M5 import *\nfrom hardware import Pin\nfrom hardware import I2C\nfrom unit import ENVUnit\nimport time\nimport machine\nrtc = machine.RTC()\nrtc.datetime((2026, 1, 9, 3, 7, 1, 0, 0))\ndef format_rtc_datetime(rtc_tuple):\n    year, month, day, weekday, hour, minute, second, subseconds = rtc_tuple\n    return \"{:04d}-{:02d}-{:02d} {:02d}:{:02d}:{:02d}\".format(year, month, day, hour, minute, second)\n\n              \nDateLabel = None\nMeteoSmith = None\nPression = None\nMesureStatus = None\nHygromtrie = None\nMeteoFile = None\ni2c0 = None\nenv4_0 = None\n\n\nDate = None\nTemp = None\nHumidity = None\nPressure = None\n\n\ndef setup():\n  global TemperatureLabel, DateLabel, MeteoSmith, Pression, Hygromtrie, MeteoFile, i2c0, env4_0, Date, Temp, Humidity, Pressure\n\n  M5.begin()\n  Widgets.setRotation(3)\n  Widgets.fillScreen(0xffffff)\n  TemperatureLabel = Widgets.Label(\"Temp \", 8, 47, 1.0, 0x000000, 0xffffff, Widgets.FONTS.DejaVu18)\n  DateLabel = Widgets.Label(\"Date\", 8, 20, 1.0, 0x000000, 0xffffff, Widgets.FONTS.DejaVu18)\n  MeteoSmith = Widgets.Title(\"MeteoSmith\", 3, 0xffffff, 0xff0000, Widgets.FONTS.DejaVu18)\n  Pression = Widgets.Label(\"Pression\", 10, 78, 1.0, 0x000000, 0xffffff, Widgets.FONTS.DejaVu18)\n  Hygromtrie = Widgets.Label(\"Hygrométrie\", 9, 106, 1.0, 0x000000, 0xffffff, Widgets.FONTS.DejaVu18)\n  i2c0 = I2C(0, scl=Pin(33), sda=Pin(32), freq=100000) \n  year, month, day, weekday, hour, minute, second, subseconds = rtc.datetime()\n  env4_0 = ENVUnit(i2c=i2c0, type=4)\n\ndef loop():\n  global TemperatureLabel, DateLabel, MeteoSmith, Pression, MesureStatus, Hygromtrie, MeteoFile, i2c0, env4_0, Date, Temp, Humidity, Pressure\n  MeteoFile = open('/flash/Meteo.csv', 'a')\n  MeteoFile.write(\"{};{};{};{}\\r\\n\".format(Temp, Pressure, Humidity, Date))\n  MeteoFile.flush()\n  MeteoFile.close()\n  Temp = env4_0.read_temperature()\n  Pressure = env4_0.read_pressure()\n  Humidity = env4_0.read_humidity()\n  year, month, day, weekday, hour, minute, second, subseconds = rtc.datetime()\n  Date = format_rtc_datetime(rtc.datetime())\n  TemperatureLabel.setText(str((str('Temp :') + str(((str(Temp) + str('C')))))))\n  Pression.setText(str((str('Pression :') + str(((str(Pressure) + str('hPa')))))))\n  Hygromtrie.setText(str((str('Hygrometrie :') + str(((str(Humidity) + str('%')))))))\n  DateLabel.setText(str(Date))\n  time.sleep(60)\n\n\nif __name__ == '__main__':\n  try:\n    setup()\n    while True:\n      loop()\n  except (Exception, KeyboardInterrupt) as e:\n    try:\n      from utility import print_error_msg\n      print_error_msg(e)\n    except ImportError:\n      print(\"please update to latest firmware\")\n","customList":[]}